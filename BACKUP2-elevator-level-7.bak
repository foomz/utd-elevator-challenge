export default class Elevator {
  constructor() {
    this.currentFloor = 0
    this.stops = 0
    this.floorsTraversed = 0
    this.requests = []
    this.riders= []
  }

  dispatch(){
    while(this.requests.length > 0 || this.riders.length > 0) {
      let nextDestination = null;

      // Determine next destination - prioritize pickups
      if(this.requests.length > 0) {
        nextDestination = this.requests[0].currentFloor;
      } else if(this.riders.length > 0) {
        nextDestination = this.riders[0].dropOffFloor;
      }

      if(nextDestination === null) break;

      // Move to next destination
      while(this.currentFloor !== nextDestination) {
        if(this.currentFloor < nextDestination) {
          this.moveUp();
        } else {
          this.moveDown();
        }
      }

      // Handle pickups and dropoffs at current floor
      this.hasPickup();
      this.hasDropoff();
    }

    // Return to lobby if conditions met
    if(this.checkReturnToLoby()) {
      this.returnToLoby();
    }
  }

  goToFloor(person, shouldReturnToLoby = true){  
    // Move to pickup floor
    while(this.currentFloor !== person.currentFloor) {
      if(this.currentFloor < person.currentFloor) {
        this.moveUp();
      } else {
        this.moveDown();
      }
    }
    // Pick up person
    this.hasPickup();
    
    // Move to dropoff floor
    while(this.currentFloor !== person.dropOffFloor) {
      if(this.currentFloor < person.dropOffFloor) {
        this.moveUp();
      } else {
        this.moveDown();
      }
    }
    // Drop off person
    this.hasDropoff();
    
    // Return to lobby if conditions met and shouldReturnToLoby is true
    if(shouldReturnToLoby && this.checkReturnToLoby()) {
      this.returnToLoby();
    }
  }

  moveUp(){
    this.currentFloor++
    this.floorsTraversed++
  }

  moveDown(){
    if(this.currentFloor > 0){      
      this.currentFloor--
      this.floorsTraversed++
    }
  }

  hasStop(){
    // Check if there's a pickup at current floor
    for(let request of this.requests) {
      if(request.currentFloor === this.currentFloor) {
        return true;
      }
    }
    // Check if there's a dropoff at current floor
    for(let rider of this.riders) {
      if(rider.dropOffFloor === this.currentFloor) {
        return true;
      }
    }
    return false;
  }

  hasPickup(){
    // Move person from requests to riders
    for(let i = 0; i < this.requests.length; i++) {
      if(this.requests[i].currentFloor === this.currentFloor) {
        let person = this.requests.splice(i, 1)[0];
        this.riders.push(person);
        this.stops++;
        break;
      }
    }
  }

  hasDropoff(){
    // Remove person from riders at their dropoff floor
    for(let i = 0; i < this.riders.length; i++) {
      if(this.riders[i].dropOffFloor === this.currentFloor) {
        this.riders.splice(i, 1);
        this.stops++;
        break;
      }
    }
  }

  checkReturnToLoby(){
    // Return to lobby if no riders and time is before 12 PM
    return this.riders.length === 0 && new Date().getHours() < 12;
  }

  returnToLoby(){
    while(this.currentFloor > 0){
      this.moveDown()
    }
  }

  reset(){
    this.currentFloor = 0
    this.stops = 0
    this.floorsTraversed = 0
    this.riders = []
  }
}